POST {{gatewayUrl}}/api/v1/chat/stream/conv-flux-img-001
Content-Type: application/json
Authorization: Bearer {{userToken}}
Accept: text/event-stream

{
  "prompt": "Generate an image of a steampunk clocktower at midnight.",
  "assetIds": [],
  "model": "argmaxinc/mlx-FLUX.1-schnell-4bit-quantized",
  "pipelineId": "default"
